# Server
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/invenzaa

# JWT (use strong secrets in production)
JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret

# CORS (comma-separated for multiple origins)
CLIENT_URL=http://localhost:5173

# Mail (SMTP)
# Set these for invite/reset emails. Keep MAIL_PASS as app password, not account password.
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
MAIL_SECURE=false

# Provider templates (choose one and copy values)
# Gmail:
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=yourname@gmail.com
# MAIL_PASS=your-16-char-app-password
# MAIL_FROM="Invenzaa <yourname@gmail.com>"
# MAIL_SECURE=false

# Outlook / Microsoft 365:
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_USER=you@outlook.com
# MAIL_PASS=your-app-password-or-mail-password
# MAIL_FROM="Invenzaa <you@outlook.com>"
# MAIL_SECURE=false

# Zoho Mail:
# MAIL_HOST=smtp.zoho.com
# MAIL_PORT=587
# MAIL_USER=you@yourdomain.com
# MAIL_PASS=your-app-password
# MAIL_FROM="Invenzaa <you@yourdomain.com>"
# MAIL_SECURE=false

# Rate limiting
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=debug
# LOG_FILE=logs/error.log

# Seeder (optional)
# SEEDER_ADMIN_EMAIL=admin@invenzaa.com
# SEEDER_ADMIN_PASSWORD=Admin123!
# SEEDER_ORG_NAME=Demo Pharmacy
